# ICSS Booking System — Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────────────
# Use a full connection string OR individual fields
DATABASE_URL=postgresql://user:password@localhost:5432/icss_bookings
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=icss_bookings
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# ─── JWT Auth ─────────────────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=admin@icssbookings.com

# ─── Payments ─────────────────────────────────────────────
# WiPay (Jamaica)
WIPAY_ACCOUNT_NUMBER=1234567890
WIPAY_API_KEY=your_wipay_api_key
WIPAY_ENVIRONMENT=sandbox    # sandbox | live

# Stripe (International — future)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Feature Flags (Global Defaults) ──────────────────────
ENABLE_DESIGN_INQUIRIES=true
ENABLE_SUBSCRIPTION_ENFORCEMENT=false   # Set true in production

# ─── Calendar Sync (OAuth & Encryption) ───────────────────
# Secret key used for AES-256-GCM encryption of OAuth tokens in DB
# Must be exactly 32 bytes (64 hex characters)
TOKEN_ENCRYPTION_KEY=change_me_to_a_32_byte_hex_string_for_production
# Google Calendar
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/calendar/oauth2callback/google
# Microsoft Graph (Outlook 365)
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/v1/calendar/oauth2callback/microsoft
